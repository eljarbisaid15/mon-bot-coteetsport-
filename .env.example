# ════════════════════════════════════════════════════════
# Variables d'environnement — à configurer sur Railway
# ════════════════════════════════════════════════════════

# ── Base44 API (OBLIGATOIRE) ─────────────────────────────
# Trouvez votre APP_ID dans l'URL : app.base44.com/apps/VOTRE_APP_ID/...
BASE44_APP_ID=votre_app_id_ici

# Trouvez votre API_KEY dans votre app Base44 :
# Settings (icône engrenage) → API Keys → Créer une clé
BASE44_API_KEY=votre_api_key_ici

# ── 2captcha (OBLIGATOIRE si CAPTCHA présent) ────────────
# Créez un compte sur 2captcha.com, rechargez 3$ minimum
TWOCAPTCHA_API_KEY=votre_cle_2captcha_ici

# ── Port (NE PAS MODIFIER — Railway le gère) ─────────────
# PORT est automatiquement injecté par Railway
